              "type": "complete"
            }
          }
        },
        {
          "label": "cycle",
          "overrides": {
            "topology": {
              "type": "cycle"
            }
          }
        },
        {
          "label": "small_world_k4_p01",
          "overrides": {
            "topology": {
              "type": "small_world",
              "degree": 4,
              "rewiring_probability": 0.1
            }
          }
        },
        {
          "label": "erdos_renyi_p02",
